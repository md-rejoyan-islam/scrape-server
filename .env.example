# Server
PORT=3000
NODE_ENV=development

# Bot bypass (true = attempt to bypass Cloudflare/bot protection, false = skip)
BOT_BYPASS_ENABLED=true

# Show browser visibly locally (false = visible, true = hidden)
HEADLESS=false

# Chokidar polling (required for Docker on Windows for hot-reload)
CHOKIDAR_USEPOLLING=true
